{
    "name": "bridge-vscode",
    "displayName": "Bridge",
    "description": "A component-based orchestration platform for VS Code.",
    "version": "0.4.0",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "main": "./src/extension.js",
    "activationEvents": [
        "onCommand:bridge.initializeWorkspace",
        "workspaceContains:**/.bridge/config.json"
    ],
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "bridge-container",
                    "title": "Bridge",
                    "icon": "$(plug)"
                }
            ],
            "panel": [
                {
                    "id": "bridge-panel-container",
                    "title": "Bridge Terminal",
                    "icon": "$(terminal)"
                }
            ]
        },
        "views": {
            "bridge-container": [
                {
                    "type": "webview",
                    "id": "bridge.sidebar",
                    "name": "Bridge",
                    "when": "bridge.workspaceInitialized"
                }
            ],
            "bridge-panel-container": [
                {
                    "type": "webview",
                    "id": "bridge.bottombar",
                    "name": "Bridge Terminal",
                    "when": "bridge.workspaceInitialized"
                }
            ]
        },
        "commands": [
            {
                "command": "bridge.initializeWorkspace",
                "title": "Initialize Workspace",
                "category": "Bridge"
            }
        ]
    },
    "dependencies": {
        "semver": "^7.5.4"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "eslint": "^8.41.0"
    }
}