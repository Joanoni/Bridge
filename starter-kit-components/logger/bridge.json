{
    "name": "Logger",
    "version": "1.0.0",
    "description": "Provides a centralized logging service for the Bridge platform.",
    "main": "index.js",
    "provides": "core:logger",
    "dependsOn": [
        "core:updater"
    ],
    "interface": {
        "log": {
            "type": "function",
            "description": "Logs an informational message."
        },
        "warn": {
            "type": "function",
            "description": "Logs a warning message."
        },
        "error": {
            "type": "function",
            "description": "Logs an error message."
        }
    }
}